<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Personal Expense Tracker</title>

<style>
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

html{
scroll-behavior:smooth;
}

body{
background:#f4f6f9;
color:#333;
}

header{
background:#0d6efd;
color:white;
padding:15px 50px;
position:sticky;
top:0;
z-index:1000;
}

nav{
display:flex;
justify-content:space-between;
align-items:center;
}

.logo{
font-size:24px;
font-weight:bold;
}

nav ul{
display:flex;
list-style:none;
}

nav ul li{
margin-left:20px;
}

nav ul li a{
text-decoration:none;
color:white;
font-weight:bold;
}

.hero{
height:90vh;
display:flex;
flex-direction:column;
justify-content:center;
align-items:center;
text-align:center;
background:linear-gradient(rgba(0,0,0,.6),rgba(0,0,0,.6)),
url('https://images.unsplash.com/photo-1554224155-6726b3ff858f');
background-size:cover;
color:white;
}

.hero h1{
font-size:50px;
}

.hero p{
margin-top:15px;
font-size:20px;
}

.btn{
margin-top:20px;
padding:12px 25px;
background:#ffc107;
border:none;
border-radius:5px;
cursor:pointer;
font-size:18px;
}

section{
padding:60px 40px;
}

.title{
text-align:center;
margin-bottom:30px;
font-size:35px;
color:#0d6efd;
}

.about,.features{
max-width:1100px;
margin:auto;
}

.feature-grid{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
gap:20px;
}

.card{
background:white;
padding:25px;
border-radius:10px;
box-shadow:0 0 10px rgba(0,0,0,.1);
text-align:center;
}

.tracker{
max-width:900px;
margin:auto;
background:white;
padding:30px;
border-radius:15px;
box-shadow:0 0 15px rgba(0,0,0,.1);
}

input,select{
width:100%;
padding:12px;
margin:10px 0;
border:1px solid #ccc;
border-radius:5px;
}

button{
background:#0d6efd;
color:white;
padding:12px;
border:none;
width:100%;
cursor:pointer;
border-radius:5px;
}

.summary{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(200px,1fr));
gap:20px;
margin-top:20px;
}

.box{
padding:20px;
border-radius:10px;
color:white;
text-align:center;
}

.income{
background:#198754;
}

.expense{
background:#dc3545;
}

.balance{
background:#0d6efd;
}

table{
width:100%;
margin-top:20px;
border-collapse:collapse;
}

table th,table td{
padding:10px;
border:1px solid #ddd;
text-align:center;
}

.contact{
max-width:700px;
margin:auto;
}

footer{
background:#212529;
color:white;
text-align:center;
padding:20px;
}

@media(max-width:768px){
.hero h1{
font-size:35px;
}
}
</style>
</head>
<body>

<header>
<nav>
<div class="logo">Expense Tracker</div>

<ul>
<li><a href="#home">Home</a></li>
<li><a href="#about">About</a></li>
<li><a href="#features">Features</a></li>
<li><a href="#tracker">Tracker</a></li>
<li><a href="#contact">Contact</a></li>
</ul>
</nav>
</header>

<section class="hero" id="home">
<h1>Personal Expense Tracker</h1>
<p>Manage Income, Expenses and Savings Efficiently</p>
<a href="#tracker">
<button class="btn">Get Started</button>
</a>
</section>

<section id="about">
<h2 class="title">About Project</h2>
<div class="about">
<p>
This Personal Expense Tracker helps users monitor their financial activities.
Users can add income and expenses, categorize transactions,
and track their balance in real time.
</p>
</div>
</section>

<section id="features">
<h2 class="title">Features</h2>

<div class="feature-grid">
<div class="card">
<h3>Income Tracking</h3>
<p>Record all income sources.</p>
</div>

<div class="card">
<h3>Expense Tracking</h3>
<p>Monitor daily spending.</p>
</div>

<div class="card">
<h3>Balance Calculator</h3>
<p>Automatic calculations.</p>
</div>

<div class="card">
<h3>Data Storage</h3>
<p>Stores records in browser.</p>
</div>
</div>
</section>

<section id="tracker">
<h2 class="title">Expense Tracker Dashboard</h2>

<div class="tracker">

<input type="text" id="desc" placeholder="Transaction Description">

<input type="number" id="amount" placeholder="Amount">

<select id="type">
<option value="income">Income</option>
<option value="expense">Expense</option>
</select>

<select id="category">
<option>Salary</option>
<option>Food</option>
<option>Travel</option>
<option>Shopping</option>
<option>Bills</option>
<option>Others</option>
</select>

<button onclick="addTransaction()">Add Transaction</button>

<div class="summary">

<div class="box income">
<h3>Total Income</h3>
<h2 id="income">₹0</h2>
</div>

<div class="box expense">
<h3>Total Expense</h3>
<h2 id="expense">₹0</h2>
</div>

<div class="box balance">
<h3>Balance</h3>
<h2 id="balance">₹0</h2>
</div>

</div>

<table>
<thead>
<tr>
<th>Description</th>
<th>Category</th>
<th>Type</th>
<th>Amount</th>
</tr>
</thead>

<tbody id="list"></tbody>

</table>

</div>
</section>

<section id="contact">
<h2 class="title">Contact Us</h2>

<div class="contact">
<input type="text" placeholder="Your Name">
<input type="email" placeholder="Email">
<input type="text" placeholder="Message">
<button>Send Message</button>
</div>
</section>

<footer>
<p>Personal Expense Tracker Project © 2026</p>
</footer>

<script>

let transactions =
JSON.parse(localStorage.getItem("transactions")) || [];

function saveData(){
localStorage.setItem(
"transactions",
JSON.stringify(transactions)
);
}

function updateUI(){

let income=0;
let expense=0;

let rows="";

transactions.forEach(item=>{

if(item.type==="income")
income+=item.amount;
else
expense+=item.amount;

rows+=`
<tr>
<td>${item.desc}</td>
<td>${item.category}</td>
<td>${item.type}</td>
<td>₹${item.amount}</td>
</tr>
`;

});

document.getElementById("list").innerHTML=rows;

document.getElementById("income").innerText=
"₹"+income;

document.getElementById("expense").innerText=
"₹"+expense;

document.getElementById("balance").innerText=
"₹"+(income-expense);

saveData();
}

function addTransaction(){

let desc=
document.getElementById("desc").value;

let amount=
parseFloat(
document.getElementById("amount").value
);

let type=
document.getElementById("type").value;

let category=
document.getElementById("category").value;

if(desc==="" || isNaN(amount)){
alert("Please fill all fields");
return;
}

transactions.push({
desc,
amount,
type,
category
});

updateUI();

document.getElementById("desc").value="";
document.getElementById("amount").value="";
}

updateUI();

</script>

</body>
</html>
